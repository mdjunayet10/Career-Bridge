PORT=4000
NODE_ENV=development
DATABASE_URL="postgresql://career_bridge:career_bridge_password@localhost:5432/career_bridge?schema=public"
JWT_SECRET="change-this-local-development-secret"
JWT_EXPIRES_IN=8h
PASSWORD_RESET_TOKEN_MINUTES=30
FRONTEND_URL=http://localhost:4000
ALLOWED_ORIGINS=*
CLIENT_ORIGIN=*
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=240
AUTH_RATE_LIMIT_MAX=30
TRUST_PROXY=false
JSON_BODY_LIMIT=1mb
MAX_CV_UPLOAD_MB=5
MORGAN_FORMAT=dev
PRISMA_LOG=false

# Email settings for password reset verification-code delivery.
# Configure these to send real codes to user email addresses.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_REQUIRE_TLS=false
SMTP_IGNORE_TLS=false
EMAIL_FROM="Career Bridge <no-reply@careerbridge.com>"

# Keep false for normal behavior. If true in non-production, the API may return
# the reset code for local demos when SMTP is not configured.
SHOW_DEVELOPMENT_RESET_CODE=false
